# ── Supabase ──────────────────────────────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# ── OpenRouter (server-side only — set in Vercel dashboard, not .env) ─────────
# Used by api/analyze-image.js (Vercel serverless). Never expose in browser.
OPENROUTER_API_KEY=sk-or-v1-your-key

# ── App URL ───────────────────────────────────────────────────────────────────
REACT_APP_BASE_URL=https://collatiq.vercel.app
